#include <Adafruit_GFX.h>    
#include <Adafruit_ST7789.h> 
#include <SPI.h>
#include <WiFi.h>
#include <PubSubClient.h>

// --- 1. ตั้งค่า WiFi และ NETPIE ---
const char* ssid     = " ";
const char* password = " ";
const char* mqtt_server = "broker.netpie.io";
const char* client_id   = " ";
const char* token       = " ";
const char* secret      = " ";

// --- 2. ตั้งค่าพินอุปกรณ์ ---
#define TFT_CS     5   
#define TFT_RS     14   
#define TFT_RST    4   
#define TFT_MOSI   23  // ต่อเข้าพิน 23 (Hardware SPI)
#define TFT_SCLK   18  // ต่อเข้าพิน 18 (Hardware SPI)

#define EC_PIN     34          
#define K_VALUE    0.985
const int pingPin  = 13; 
const int inPin    = 12;   

// --- 3. ประกาศ Object ---
Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_RS, TFT_RST);
WiFiClient espClient;
PubSubClient client(espClient);

// ตัวแปรบริหารเวลา (แทนการใช้ delay)
unsigned long lastDisplayUpdate = 0;
unsigned long lastNetpieSend    = 0;

// --- ฟังก์ชันเสริม ---
float microsecondsToCentimeters(long microseconds) {
  return (float)microseconds / 29.0 / 2.0;
}

void setup_wifi() {
  if (WiFi.status() == WL_CONNECTED) return;
  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500); Serial.print(".");
  }
  Serial.println("\nWiFi Connected");
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    if (client.connect(client_id, token, secret)) {
      Serial.println("Connected to NETPIE");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(9600);
  
  // Setup Sensor & TFT
  pinMode(EC_PIN, INPUT);
  analogReadResolution(12);
  
  tft.init(240, 320, SPI_MODE2); 
  tft.setRotation(1); 
  tft.invertDisplay(true);
  tft.fillScreen(ST77XX_BLACK);

  // วาดโครงสร้างหน้าจอครั้งเดียว
  tft.drawFastHLine(0, 35, 320, ST77XX_WHITE);
  tft.setTextColor(ST77XX_CYAN);
  tft.setTextSize(2);
  tft.setCursor(20, 10);
  tft.print("MULTI-SENSOR SYSTEM");

  setup_wifi();
  client.setServer(mqtt_server, 1883);
}

void loop() {
  // รักษาการเชื่อมต่อ
  if (WiFi.status() != WL_CONNECTED) setup_wifi();
  if (!client.connected()) reconnect();
  client.loop();

  // --- ส่วนที่ 1: อ่านค่าเซนเซอร์และอัปเดตจอ (ทุก 500 ms) ---
  if (millis() - lastDisplayUpdate > 500) {
    lastDisplayUpdate = millis();

    // อ่าน Ultrasonic
    pinMode(pingPin, OUTPUT);
    digitalWrite(pingPin, LOW); delayMicroseconds(2);
    digitalWrite(pingPin, HIGH); delayMicroseconds(5);
    digitalWrite(pingPin, LOW);
    pinMode(inPin, INPUT);
    long duration = pulseIn(inPin, HIGH, 30000);
    float averageCm = microsecondsToCentimeters(duration);

    // อ่าน EC
    long sumEC = 0;
    for (int i = 0; i < 20; i++) { sumEC += analogRead(EC_PIN); delay(10); }
    float voltage = (sumEC / 20.0 / 4095.0) * 3.3;
    float ecValue = (voltage * 5.0) * K_VALUE;

    // แสดงผลจอ TFT (ใช้สีพื้นหลังทับเพื่อกันกะพริบ)
    tft.setTextSize(2);
    tft.setCursor(20, 50); tft.setTextColor(ST77XX_GREEN, ST77XX_BLACK);
    tft.print("EC VALUE:");
    tft.setCursor(20, 75); tft.setTextSize(5);
    tft.print(ecValue, 1); tft.setTextSize(2); tft.print(" ms   ");

    tft.setCursor(20, 140); tft.setTextColor(ST77XX_YELLOW, ST77XX_BLACK);
    tft.print("DISTANCE:");
    tft.setCursor(20, 165); tft.setTextSize(5);
    tft.print(averageCm, 1); tft.setTextSize(2); tft.print(" cm   ");
    
    // --- ส่วนที่ 2: ส่งข้อมูลไป NETPIE (ทุก 1 วินาที) ---
    if (millis() - lastNetpieSend > 1000) {
      lastNetpieSend = millis();

      String payload = "{\"data\": {\"ec\":" + String(ecValue, 2) +
                      ", \"distance\":" + String(averageCm, 2) +
                      ", \"voltage\":" + String(voltage, 3) + "}}";

      client.publish("@shadow/data/update", payload.c_str());
      client.publish("@feed", payload.c_str());
      Serial.println("Sent: " + payload);
    }
  }
}
