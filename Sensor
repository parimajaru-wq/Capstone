#include <Adafruit_GFX.h>    
#include <Adafruit_ST7789.h> 
#include <SPI.h>

// --- ตั้งค่าพินจอ TFT (ตามรูปภาพเดิมของคุณ) ---
#define TFT_CS    5   
#define TFT_RS    2   // หรือ DC
#define TFT_RST   4   
// --- ตั้งค่าพิน EC Sensor ---
#define EC_PIN    34          
#define K_VALUE   0.985
// --- ตั้งค่าพิน Ultrasonic (ตามโค้ดใหม่ของคุณ) ---
const int pingPin = 13; // Trig
int inPin = 12;         // Echo

Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_RS, TFT_RST);

void setup() {
  Serial.begin(9600);
  pinMode(EC_PIN, INPUT);
  analogReadResolution(12);

  // เริ่มต้นจอภาพ
  pinMode(TFT_RST, OUTPUT);
  digitalWrite(TFT_RST, LOW);  delay(100);
  digitalWrite(TFT_RST, HIGH); delay(100);
  
  tft.init(240, 320, SPI_MODE2); 
  tft.setRotation(1); 
  tft.invertDisplay(true);
  tft.fillScreen(ST77XX_BLACK);

  // วาดหัวข้อหน้าจอ
  tft.setTextColor(ST77XX_CYAN);
  tft.setTextSize(2);
  tft.setCursor(20, 10);
  tft.println("MULTI-SENSOR SYSTEM");
  tft.drawFastHLine(0, 35, 320, ST77XX_WHITE);
}

void loop() {
  // --- 1. อ่านค่า Ultrasonic (วัดระยะทาง) ---
  long duration, cm;
  pinMode(pingPin, OUTPUT);
  digitalWrite(pingPin, LOW);
  delayMicroseconds(2);
  digitalWrite(pingPin, HIGH);
  delayMicroseconds(5);
  digitalWrite(pingPin, LOW);
  
  pinMode(inPin, INPUT);
  duration = pulseIn(inPin, HIGH);
  cm = duration / 29 / 2; // สูตรคำนวณเซนติเมตร

  // --- 2. อ่านค่า EC Sensor ---
  long sum = 0;
  for (int i = 0; i < 40; i++) {
    sum += analogRead(EC_PIN);
    delay(2);
  }
  float averageADC = sum / 40.0;
  float voltage = (averageADC / 4095.0) * 3.3;
  float ecValue = (voltage * 5.0) * K_VALUE;
  if (ecValue < 0) ecValue = 0;

  // --- 3. แสดงผลบนหน้าจอ ---
  // พื้นที่แสดง EC
  tft.fillRect(20, 50, 280, 70, ST77XX_BLACK); // ล้างค่าเก่า
  tft.setCursor(20, 60);
  tft.setTextColor(ST77XX_GREEN);
  tft.setTextSize(2);
  tft.print("EC: ");
  tft.setTextSize(5);
  tft.print(ecValue, 1);
  tft.setTextSize(2);
  tft.print(" ms");

  // พื้นที่แสดงระยะทาง (Distance)
  tft.fillRect(20, 140, 280, 70, ST77XX_BLACK); // ล้างค่าเก่า
  tft.setCursor(20, 150);
  tft.setTextColor(ST77XX_YELLOW);
  tft.setTextSize(2);
  tft.print("Dist: ");
  tft.setTextSize(5);
  tft.print(cm);
  tft.setTextSize(2);
  tft.print(" cm");

  // ปริ้นออก Serial Monitor
  Serial.print("EC: "); Serial.print(ecValue);
  Serial.print(" | Dist: "); Serial.print(cm); Serial.println("cm");

  delay(500); // อัปเดตทุก 0.5 วินาที
}
